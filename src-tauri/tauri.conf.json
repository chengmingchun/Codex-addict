{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Intra Codex",
  "version": "0.1.0",
  "identifier": "com.intra.codex",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Intra Codex",
        "width": 1320,
        "height": 820,
        "minWidth": 820,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../config": "config",
      "../skills": "skills"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
